# Lamadrid Labs — Hostinger static export config
# Copied into out/ by the deploy workflow before upload. Edit here, not on the server.

# --- Custom 404 ---
ErrorDocument 404 /404.html

# --- HTTPS + apex canonicalization ---
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force apex (non-www)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# --- MIME types (extensionless OG/Twitter image routes, webmanifest) ---
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# --- Cache headers ---
# FilesMatch only sees the basename, so path-scoped rules (hashed Next.js
# assets under /_next/static/) go through a RewriteRule env flag instead.
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_URI} ^/_next/static/
  RewriteRule .* - [E=CACHE_IMMUTABLE:1]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable" env=CACHE_IMMUTABLE
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
